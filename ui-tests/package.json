{
  "name": "jupyterlab-plugin-playground-ui-tests",
  "version": "1.0.0",
  "description": "JupyterLab Plugin Playground integration tests",
  "private": true,
  "scripts": {
    "start": "jupyter lab --config jupyter_server_test_config.py",
    "start:notebook": "jupyter notebook --config jupyter_server_test_config.py",
    "test": "jlpm playwright test",
    "test:notebook": "jlpm playwright test --config playwright.notebook.config.js",
    "test:docs-screenshots": "jlpm playwright test --config playwright.docs.config.js",
    "test:update": "jlpm playwright test --update-snapshots"
  },
  "devDependencies": {
    "@jupyterlab/galata": "5.5.5",
    "@playwright/test": "1.58.2"
  }
}
